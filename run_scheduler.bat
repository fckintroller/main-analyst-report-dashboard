@echo off
title Analyst Database Auto Updater
chcp 65001 > nul

echo ==========================================================
echo       베스트 애널리스트 데이터베이스 자동 업데이트 (2주 주기)
echo ==========================================================
echo.
echo [알림] 데이터베이스(analyst_database.json)를 로딩하여
echo        1) 마크다운 보고서(analyst_awards_report.md)
echo        2) 구글 시트 연동용 CSV(analyst_table_sheet.csv)
echo        3) 02_outputs 공식 기록용 타임스탬프 백업 사본
echo        을 실시간 동적 갱신합니다.
echo.
echo 업데이트 진행 중...
echo.

:: python 실행 파일 탐색 및 실행
python "%~dp0updater.py"

if %errorlevel% neq 0 (
    echo.
    echo [에러] 업데이트 도중 문제가 발생했습니다. 파이썬 환경을 확인해 주십시오.
    pause
    exit /b %errorlevel%
)

echo.
echo ==========================================================
echo [성공] 모든 파일이 완벽하게 동적 업데이트 되었습니다!
echo ==========================================================
echo.
echo ----------------------------------------------------------
echo 💡 [2주 주기 자동 업데이트 등록 가이드 - Windows 작업 스케줄러]
echo ----------------------------------------------------------
echo 1. 윈도우 시작 메뉴에서 '작업 스케줄러' 또는 'Task Scheduler'를 검색하여 엽니다.
echo 2. 우측 메뉴에서 '기본 작업 만들기' (Create Basic Task)를 선택합니다.
echo 3. 이름: '베스트 애널리스트 데이터베이스 자동 갱신 스케줄러' 입력 후 다음.
echo 4. 작업 트리거: '매월' (Monthly) 또는 '매주' 선택 (2주 간격을 맞추기 위해 '매주' 선택 후 2주마다 일요일에 실행 권장).
echo 5. 동작: '프로그램 시작' (Start a program) 선택 후 다음.
echo 6. 프로그램/스크립트: 아래의 배치파일 전체 경로를 입력합니다.
echo    경로: "%~dp0run_scheduler.bat"
echo 7. 완료를 누르시면 2주마다 주기적으로 백그라운드 자동 갱신이 시행됩니다!
echo ----------------------------------------------------------
echo.
pause
